# COCSO Agent — Environment Configuration
# Copy this file to .env and fill in only what you need.
# Defaults are lean: nothing here is required to boot. Add keys as you turn
# features on. Most config lives in ~/.cocso/config.yaml — env is just
# secrets and runtime overrides.

# =============================================================================
# COCSO — 회사/MCP 식별
# =============================================================================
# 회사 데이터에 접근하려면 아래 값을 채우세요.
# MCP는 두 종류:
#   • Client MCP  — cocso-client  (URL + COCSO_CLIENT_KEY)
#   • Service MCP — cocso-service (URL + COCSO_SERVICE_KEY)
# URL 또는 KEY 중 하나라도 비어있으면 해당 MCP 서버는 등록되지 않습니다.
# 둘 다 설정 필요 없음 — 사용하는 MCP만 채우면 됩니다.

# 회사명 — 에이전트 페르소나 / 배너에 표시
# COCSO_COMPANY_NAME=

# --- Client MCP ---
# COCSO_CLIENT_MCP_URL=
# COCSO_CLIENT_KEY=

# --- Service MCP ---
# COCSO_SERVICE_MCP_URL=
# COCSO_SERVICE_KEY=

# =============================================================================
# MODEL PROVIDERS
# =============================================================================
# COCSO supports a small, focused set of providers. Pick one (or several).

# --- Claude (Anthropic) ---
# Get a key at: https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=

# --- GPT / Codex (OpenAI) ---
# Powers GPT family models and the Codex CLI provider.
# Get a key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# OPENAI_BASE_URL=

# --- MiMo (Xiaomi) ---
# mimo-v2-pro / mimo-v2-omni / mimo-v2-flash.
# Get a key at: https://platform.xiaomimimo.com
# XIAOMI_API_KEY=
# XIAOMI_BASE_URL=https://api.xiaomimimo.com/v1

# --- Local model (Ollama, LM Studio, vLLM, …) ---
# Anything OpenAI-compatible on localhost. No API key required for most.
# LM_BASE_URL=http://localhost:11434/v1
# LM_API_KEY=

# --- OpenRouter (200+ models via OpenAI-compatible API) ---
# One key, one endpoint, access to Anthropic / OpenAI / Google / Meta / DeepSeek
# / Qwen / and more. Useful for trying many models without separate accounts.
# Get a key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Custom provider (any OpenAI-compatible endpoint) ---
# Use this slot for self-hosted gateways, proxies, or providers not above.
# Set base URL + key, then point your model at it via `cocso model`.
# OPENAI_BASE_URL=https://your-gateway.example.com/v1
# OPENAI_API_KEY=...

# =============================================================================
# MESSAGING PLATFORMS
# =============================================================================
# COCSO currently ships gateways for three platforms. Set the token for the
# one(s) you use; the others stay dark.

# --- Discord ---
# Get a token from: https://discord.com/developers/applications
# DISCORD_BOT_TOKEN=
# DISCORD_ALLOWED_USERS=                # Comma-separated user IDs
# DISCORD_HOME_CHANNEL=                 # Default channel for cron delivery

# --- Slack ---
# Get tokens from: https://api.slack.com/apps  (Socket Mode app)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_APP_TOKEN=xapp-...
# SLACK_ALLOWED_USERS=

# --- Telegram ---
# Get a token from: @BotFather on Telegram (https://t.me/BotFather)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=
# TELEGRAM_HOME_CHANNEL=
# Optional webhook mode (default is long polling):
# TELEGRAM_WEBHOOK_URL=
# TELEGRAM_WEBHOOK_PORT=8443
# TELEGRAM_WEBHOOK_SECRET=

# Gateway-wide: allow ALL users without an allowlist (default: false = deny).
# Only set true if you intentionally want open access.
# GATEWAY_ALLOW_ALL_USERS=false

# =============================================================================
# TERMINAL TOOL
# =============================================================================
# Where the agent runs shell commands. "local" is the default.
# Supported backends: local, docker, ssh.
# Configure via `cocso setup` or in ~/.cocso/config.yaml (terminal.backend).
# TERMINAL_ENV=local
# TERMINAL_TIMEOUT=60
# TERMINAL_LIFETIME_SECONDS=300

# SSH backend — run shell on a remote host (agent stays local).
# TERMINAL_SSH_HOST=
# TERMINAL_SSH_USER=
# TERMINAL_SSH_PORT=22
# TERMINAL_SSH_KEY=~/.ssh/id_rsa

# Sudo support across backends. Plaintext — only on trusted machines.
# SUDO_PASSWORD=

# =============================================================================
# OPTIONAL TOOLS
# =============================================================================
# Web search / browser / image — all optional. Skip what you don't use.

# Web search
# EXA_API_KEY=
# FIRECRAWL_API_KEY=

# Browser automation (Browserbase cloud)
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# =============================================================================
# MCP (Model Context Protocol)
# =============================================================================
# COCSO ships zero MCP servers by default. Add your own with:
#   cocso mcp add <name> <url-or-command>
# No env keys required here.

# =============================================================================
# DEBUG
# =============================================================================
# WEB_TOOLS_DEBUG=false
# VISION_TOOLS_DEBUG=false
